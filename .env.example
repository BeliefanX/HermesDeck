# HermesDeck environment variables — copy to .env.local and fill in.

# === Hermes API connection ===
# Base URL of the Hermes API server. If unset, the deck falls back to invoking
# the `hermes` CLI directly. Example: http://127.0.0.1:8001
HERMES_API_BASE=
# Bearer token for the Hermes API server. Required when HERMES_API_BASE is set.
HERMES_API_KEY=
# Optional dashboard base used for deep links from runs/sessions.
HERMES_DASHBOARD_BASE=

# === Deck server ===
# Public origin used for CSRF same-origin checks. MUST be set in production
# behind a reverse proxy. Example: https://deck.example.com
HERMESDECK_PUBLIC_ORIGIN=
# Trust X-Forwarded-For for rate-limit keys (set to 1 only behind a known proxy).
HERMESDECK_TRUST_PROXY=0
# Comma-separated list of LAN origins permitted in `next dev` (replaces the
# hardcoded list in next.config.js).
DECK_DEV_ORIGINS=localhost,127.0.0.1,0.0.0.0

# === Live terminal ===
# Set to 1 to enable the in-browser tmux-backed PTY. Disabled by default.
HERMESDECK_LIVE_TERMINAL=0
# Override tmux binary location.
HERMESDECK_TMUX_BIN=/opt/homebrew/bin/tmux

# === Auth ===
# Session HMAC secret. Auto-generated on first boot if absent.
HERMESDECK_SESSION_SECRET=

# === Locale ===
LANG=en_US.UTF-8
